{
  "ui_font_size": 16,
  "ui_font_family": "Google Sans Flex",
  "buffer_font_size": 16,
  "buffer_font_family": "Iosevka Pacman",
  "soft_wrap": "bounded",
  "preferred_line_length": 120,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "vim_mode": true,
  "show_call_status_icon": false,
  "restore_on_startup": "empty_tab",
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
}
